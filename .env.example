# Copy this to .env and fill in your Firebase values
# Get these from: Firebase Console > Project Settings > Your Apps

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Sheets (from previous setup)
VITE_SHEETS_ID=
VITE_SHEETS_API_KEY=

# Admin dashboard secret path (generate a random UUID)
VITE_ADMIN_SLUG=admin-REPLACE_WITH_RANDOM_UUID
